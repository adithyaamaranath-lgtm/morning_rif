    {
      "parameters": {
        "jsCode": "const now = new Date();\n\n// Detects your laptop's current travel timezone automatically\nconst localTimezone = Intl.DateTimeFormat().resolvedOptions().timeZone;\n\n// Format helpers\nconst formatTime = (options) => {\n  return new Intl.DateTimeFormat('en-US', {\n    ...options,\n    timeZone: localTimezone\n  }).format(now);\n};\n\nconst parts = new Intl.DateTimeFormat('en-US', {\n  timeZone: localTimezone,\n  year: 'numeric', month: '2-digit', day: '2-digit',\n  hour: '2-digit', minute: '2-digit', second: '2-digit',\n  hour12: false\n}).formatToParts(now);\n\nconst getPart = (type) => parts.find(p => p.type === type).value;\n\nconst getOrdinalSuffix = (day) => {\n  const d = parseInt(day);\n  if (d > 3 && d < 21) return 'th';\n  switch (d % 10) {\n    case 1:  return \"st\";\n    case 2:  return \"nd\";\n    case 3:  return \"rd\";\n    default: return \"th\";\n  }\n};\n\nconst dayOfMonth = getPart('day');\nconst monthName = formatTime({ month: 'long' });\nconst ordinalDate = `${monthName} ${parseInt(dayOfMonth)}${getOrdinalSuffix(dayOfMonth)} ${getPart('year')}`;\n\nreturn [{\n  \"timestamp\": now.toISOString(),\n  \"Readable date\": `${ordinalDate}, ${formatTime({ hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true }).toLowerCase()}`,\n  \"Readable time\": formatTime({ hour: 'numeric', minute: '2-digit', second: '2-digit', hour12: true }).toLowerCase(),\n  \"Day of week\": formatTime({ weekday: 'long' }),\n  \"Year\": getPart('year'),\n  \"Month\": monthName,\n  \"Day of month\": dayOfMonth,\n  \"Hour\": getPart('hour'),\n  \"Minute\": getPart('minute'),\n  \"Second\": getPart('second'),\n  \"Timezone\": `${localTimezone} (UTC${formatTime({ timeZoneName: 'shortOffset' }).replace('GMT', '')})`\n}];\n"
      },
