    {
      "parameters": {
        "jsCode": "// 1. Grab all individual items arriving from your Limit nodes\nconst items = $input.all();\n\n// 2. Map through the individual items to extract the titles and add numbers\nconst headlines = items\n  .map((item, i) => `**${i + 1}.** ${item.json.title}`)\n  .join(\"\\n\");\n\n// 3. Return the single consolidated string formatted for your news app\nreturn [{\n  json: {\n    headlines\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        -160
      ],
      "id": "b0025a91-b54a-4556-8a05-d7806b128506",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Main data sources\nconst weather = $node[\"Weather\"].json;\nconst mergedNews = $node[\"Merge\"].json;        // ← Change \"Merge\" to your actual Merge node name\nconst quote = $node[\"Quote\"].json;\nconst location = $('Location').first().json;\n\n// Helper to safely get articles from each category\nconst getArticles = (category) => {\n  // The merged item likely contains arrays for each category\n  return mergedNews[category] || mergedNews[`${category}News`] || \n         mergedNews.articles?.filter(a => a.category === category) || [];\n};\n\n// Format headlines (same style as before)\nconst formatHeadlines = (articles) => {\n  return (articles || [])\n    .slice(0, 3)\n    .map(article => {\n      let title = article.title ? article.title.split(\" - \")[0] : \"Untitled\";\n      if (title.length > 85) title = title.slice(0, 82) + \"...\";\n      return `• ${title}`;\n    })\n    .join(\"\\n\");\n};\n\n// Weather formatting\nconst temp = Math.round(weather.main.temp);\nconst feelsLike = Math.round(weather.main.feels_like);\nconst humidity = weather.main.humidity;\nconst wind = Math.round(weather.wind.speed);\nconst description = weather.weather[0].description\n  .replace(/\\b\\w/g, c => c.toUpperCase());\n\n// Date\nconst today = new Date().toLocaleDateString(\"en-US\", {\n  weekday: \"long\",\n  month: \"long\",\n  day: \"numeric\",\n});\n\n// Clothing advice\nlet advice = \"\";\nif (temp >= 90) {\n  advice = \"🥵 It's going to be very hot today. Stay hydrated and wear light clothing.\";\n} else if (temp >= 75) {\n  advice = \"👕 Warm weather today. Short sleeves should be comfortable.\";\n} else if (temp >= 60) {\n  advice = \"🧥 Mild temperatures. A light jacket may be useful this morning.\";\n} else {\n  advice = \"🧣 It's quite chilly today. Dress warmly before heading out.\";\n}\n\n// Format each section\nconst politicsHeadlines = formatHeadlines(getArticles(\"politics\"));\nconst aiHeadlines = formatHeadlines(getArticles(\"ai\"));\nconst sportsHeadlines = formatHeadlines(getArticles(\"sports\"));\n\n// Final formatted message\nconst message = `# 🌅 Good Morning!\n\n📅 **${today}**\n📍 **${location.city}, ${location.country_name}**\n\n## ☀️ Weather\n**${temp}°F** • ${description}\n🌡️ Feels like: **${feelsLike}°F**\n💧 Humidity: **${humidity}%**\n🌬️ Wind: **${wind} mph**\n\n${advice}\n\n## 🗳️ World Politics\n${politicsHeadlines || \"• No top stories right now.\"}\n\n## 🤖 AI\n${aiHeadlines || \"• No top stories right now.\"}\n\n## ⚽ Sports\n${sportsHeadlines || \"• No top stories right now.\"}\n\n## 💪 Quote of the Day\n> *\"${quote.q}\"*\n— **${quote.a}**\n\nHave an amazing day! 🚀\n─────────────────────────────`;\n\nreturn [\n  {\n    json: {\n      message\n    }\n  }\n];"
      },
